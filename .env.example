# Copy to .env and fill in values. See README.md (Getting started).

DATABASE_URL=
BETTER_AUTH_SECRET=
# Optional. On Vercel, the URL is derived from VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL automatically.
# Set this only for local dev (e.g. http://localhost:3000) or to pin a canonical production URL.
BETTER_AUTH_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
TMDB_READ_ACCESS_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional. Effect logger minimum level. One of: all, trace, debug, info, warning, error, fatal, none. Default: info.
LOG_LEVEL=
