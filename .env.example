# Copy to .env and fill in values. See README.md (Local development).

DATABASE_URL=
BETTER_AUTH_SECRET=
# Optional. On Vercel, the URL is derived from VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL automatically.
# Set this only for local dev (e.g. http://localhost:3000) or to pin a canonical production URL.
BETTER_AUTH_URL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional. Same rules as BETTER_AUTH_URL but for the client bundle.
NEXT_PUBLIC_APP_URL=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
